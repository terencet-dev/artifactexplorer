# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.tgz

# Azure Functions build artifacts
infra/azure-functions/node_modules/
infra/azure-functions/dist/

# Playwright
/playwright-report/
/test-results/
/.playwright-mcp/

# Local AI tooling
/.claude/
/.copilot/
/.cursor/

# Editor / IDE configs
/.vscode/
/.idea/
/.zed/
*.sublime-project
*.sublime-workspace

# OS junk
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Secrets — defense in depth (nothing in this repo should ever contain these)
/secrets/
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub
*.crt
# Note: *.pem is already covered under "misc" above.

# Local environment overrides
.env
