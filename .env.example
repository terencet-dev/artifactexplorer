# Artifact Explorer — example environment variables.
# Copy this file to `.env.local` and fill in the values you need.
# ALL of these are optional. Without them, the app runs as a standalone
# registry explorer (the SBOM Search feature is simply hidden).

# ============================================================================
# Public site policy / UX (baked into the client bundle at build time).
# Anything prefixed `NEXT_PUBLIC_` is shipped to browsers — never put secrets
# here.
# ============================================================================

# Set to "true" to expose the SBOM Search nav item and pages.
# Leave unset (or any other value) to hide the feature entirely.
NEXT_PUBLIC_SBOM_SEARCH_VISIBLE=""

# If set AND NODE_ENV=production, Microsoft Clarity analytics is loaded with
# this project ID. If unset, no analytics code runs. (The /privacy page
# discloses Microsoft Clarity regardless; this only controls whether the
# analytics script is actually loaded.)
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# ============================================================================
# SBOM Search (optional — only needed if you set NEXT_PUBLIC_SBOM_SEARCH_VISIBLE=true).
# ============================================================================

# PostgreSQL connection string (Supabase, Azure Database for PostgreSQL,
# or any PostgreSQL 14+ instance with the pg_trgm extension enabled).
DATABASE_URL=""

# Shared secret used to authenticate scheduled crawl invocations
# (Vercel Cron, Azure Functions, or manual triggers). Generate with:
#   openssl rand -hex 32
CRON_SECRET=""

# Where to run the SBOM crawler.
#   "vercel"  - run the crawl inline on Vercel Cron
#   "azure"   - delegate the crawl to an Azure Functions deployment
SBOM_CRAWL_PROVIDER="vercel"

# Master switch: must be "true" for the crawl HTTP endpoint to do anything.
# Defaults to false so a fresh deployment never crawls anything until you
# explicitly opt in.
CRAWL_ENABLED="false"

# The OCI registry to crawl. Leave UNSET to disable crawling — there is
# deliberately no default; you must pick a registry to point at.
#   Examples: mcr.microsoft.com / docker.io / ghcr.io / <your-account>.azurecr.io
CRAWL_DEFAULT_REGISTRY_SERVER=""
CRAWL_DEFAULT_REGISTRY_ID=""

# Crawl window (UTC hours). Both bounds are inclusive of start, exclusive of
# end. Supports wrap-around (e.g. start=22, end=6 → 22:00–06:00 UTC).
# Defaults: 01:00–14:00 UTC (off-peak in US-Pacific).
CRAWL_HOUR_START="1"
CRAWL_HOUR_END="14"

# ============================================================================
# Database SSL (optional).
# ============================================================================

# Azure PostgreSQL: paste the DigiCert CA bundle here for strict SSL.
# Leave empty for Supabase (uses permissive SSL by default).
DATABASE_SSL_CA=""

# Local development: set to "disable" if you're running Postgres without SSL.
# DATABASE_SSL_MODE="disable"

# ============================================================================
# Cross-origin access (optional).
# ============================================================================
# Comma-separated list of origins allowed to call this app's API from a
# different origin. Leave empty for same-origin only (the default — and the
# correct setting for almost everyone). Wildcards are NOT supported.
ALLOWED_ORIGINS=""

# ============================================================================
# Health-check / Azure helpers (optional — used only by scripts/health-check.sh).
# ============================================================================
DOMAIN=""
RESOURCE_GROUP=""
FUNC_APP_NAME=""
