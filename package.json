{
  "name": "artifactexplorer",
  "version": "1.0.3",
  "description": "A user-friendly explorer for OCI-compatible container registries",
  "private": false,
  "author": "Terence Truong <48969648+terencet-dev@users.noreply.github.com>",
  "license": "MIT",
  "keywords": [
    "container",
    "registry",
    "docker",
    "oci",
    "azure",
    "acr",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start-production": "next build && next start -p 3000",
    "test-prod": "NODE_ENV=production next build && NODE_ENV=production next start -p 3000",
    "lint": "eslint .",
    "clean": "rm -rf .next node_modules",
    "prebuild": "npm run lint",
    "test": "npx playwright test",
    "test:api": "npx playwright test e2e/api-health.spec.ts",
    "test:ui": "npx playwright test e2e/homepage.spec.ts e2e/navigation.spec.ts e2e/connect.spec.ts e2e/registry.spec.ts",
    "prepare-release": "npm run build && npm pack"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@tanstack/react-query": "^5.74.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "react": "^19",
    "react-dom": "^19",
    "react-hot-toast": "^2.5.2",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "wicg-inert": "^3.1.3"
  },
  "optionalDependencies": {
    "@microsoft/clarity": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=8.0.0"
  }
}
